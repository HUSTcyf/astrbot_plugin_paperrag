{
    "enabled": {
        "description": "是否启用Paper RAG插件",
        "type": "bool",
        "default": true
    },
    "embedding_mode": {
        "description": "Embedding模式",
        "type": "string",
        "hint": "选择embedding服务模式。API模式使用Gemini/OpenAI等云端服务；Ollama模式使用本地Ollama服务运行bge-m3等模型，完全免费且无限制",
        "obvious_hint": true,
        "default": "ollama",
        "enum": ["api", "ollama"]
    },
    "embedding_provider_id": {
        "description": "Embedding 服务提供商（API模式）",
        "type": "string",
        "hint": "选择用于向量嵌入的 Embedding Provider（推荐使用 Gemini）。留空则使用 AstrBot 中配置的第一个 Embedding Provider。仅在API模式下生效",
        "_special": "select_embedding_provider",
        "default": "gemini_embedding"
    },
    "llm_provider_id": {
        "description": "LLM Provider ID（用于RAG生成，已弃用）",
        "type": "string",
        "hint": "⚠️ 已弃用。请使用 glm_api_key 配置RAG回答生成",
        "obvious_hint": true,
        "default": "glm-4.6v-flash",
        "deprecated": true
    },
    "glm_api_key": {
        "description": "智谱AI API密钥（GLM-4-Flash）",
        "type": "string",
        "hint": "从 https://open.bigmodel.cn/ 获取API密钥，用于RAG回答生成。GLM-4-Flash速度快、价格低。如仅需检索功能可留空",
        "obvious_hint": true,
        "default": "",
        "minLength": 0
    },
    "glm_model": {
        "description": "GLM模型名称",
        "type": "string",
        "hint": "选择GLM模型版本。glm-4.7-flash: 快速响应（推荐）；glm-4: 标准性能；glm-4-plus: 高质量输出",
        "default": "glm-4.7-flash",
        "enum": ["glm-4.7-flash", "glm-4", "glm-4-plus"]
    },
    "embedding_model": {
        "description": "API Embedding模型名称（已弃用）",
        "type": "string",
        "hint": "⚠️ 已弃用。请使用 embedding_provider_id 选择Provider",
        "default": "",
        "minLength": 0,
        "deprecated": true
    },
    "use_llama_index": {
        "description": "使用llama-index引擎（已弃用）",
        "type": "bool",
        "hint": "⚠️ 已弃用。现在强制使用混合引擎",
        "default": true,
        "deprecated": true
    },
    "milvus_lite_path": {
        "description": "Milvus Lite 数据库路径",
        "type": "string",
        "hint": "数据库文件路径。留空则使用插件目录下的 data/milvus_papers.db",
        "obvious_hint": true,
        "default": "",
        "minLength": 0
    },
    "address": {
        "description": "Milvus 数据库地址",
        "type": "string",
        "hint": "支持格式如：http://localhost:19530、https://localhost:19530、localhost:19530。如需使用远程 Milvus 服务器，请填写此项并将 milvus_lite_path 留空",
        "obvious_hint": true,
        "default": "",
        "pattern": "^(https?://)?[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(\\.[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*:[0-9]{1,5}$",
        "minLength": 0
    },
    "db_name": {
        "description": "Milvus 数据库名称",
        "type": "string",
        "hint": "Milvus 2.2+ 支持多数据库。默认使用 default，可按需配置为其他数据库名称以隔离数据",
        "obvious_hint": true,
        "default": "default",
        "pattern": "^[a-zA-Z][a-zA-Z0-9_\\-]{0,63}$",
        "minLength": 1,
        "maxLength": 64
    },
    "authentication": {
        "description": "Milvus 数据库认证信息",
        "type": "object",
        "hint": "如果 Milvus 开启了服务器认证，请填写对应的信息",
        "obvious_hint": true,
        "items": {
            "token": {
                "description": "Milvus 数据库认证 token",
                "type": "string",
                "hint": "Token 优先于账户密码",
                "obvious_hint": true,
                "minLength": 0
            },
            "user": {
                "description": "Milvus 数据库认证用户名",
                "type": "string",
                "minLength": 1
            },
            "password": {
                "description": "Milvus 数据库认证密码",
                "type": "string",
                "minLength": 0
            }
        }
    },
    "collection_name": {
        "description": "向量数据库集合名称",
        "type": "string",
        "hint": "Milvus 中存储文档向量的集合名称，建议使用英文名",
        "default": "paper_embeddings",
        "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$",
        "minLength": 1,
        "maxLength": 64
    },
    "embed_dim": {
        "description": "向量嵌入维度",
        "type": "int",
        "hint": "嵌入向量的维度，需与选择的 Embedding Provider 模型匹配。Gemini为768，OpenAI为1536",
        "default": 768,
        "minimum": 128,
        "maximum": 4096
    },
    "top_k": {
        "description": "检索返回的文档片段数量",
        "type": "int",
        "hint": "每次检索返回的最相关文档片段数量",
        "default": 5,
        "minimum": 1,
        "maximum": 20
    },
    "similarity_cutoff": {
        "description": "相似度阈值",
        "type": "float",
        "hint": "仅返回相似度高于此阈值的文档片段（0-1之间，值越高越严格）",
        "default": 0.3,
        "minimum": 0,
        "maximum": 1
    },
    "papers_dir": {
        "description": "论文文件存放目录",
        "type": "string",
        "hint": "存放PDF、Word、TXT等文档的目录路径",
        "obvious_hint": true,
        "default": "./papers"
    },
    "cache_enabled": {
        "description": "是否启用查询结果缓存",
        "type": "bool",
        "default": true
    },
    "cache_ttl_seconds": {
        "description": "缓存有效时间（秒）",
        "type": "int",
        "default": 3600,
        "minimum": 60,
        "maximum": 86400
    },
    "cache_max_entries": {
        "description": "最多缓存多少条查询结果",
        "type": "int",
        "default": 100,
        "minimum": 10,
        "maximum": 1000
    },
    "chunk_size": {
        "description": "文档分块目标大小（字符数）",
        "type": "int",
        "hint": "语义感知分块的目标块大小。较大的值会产生更少但更大的块",
        "default": 512,
        "minimum": 256,
        "maximum": 2048
    },
    "chunk_overlap": {
        "description": "分块重叠大小（字符数）",
        "type": "int",
        "hint": "相邻块之间的重叠字符数，用于保留上下文连贯性。默认0（禁用重叠）",
        "default": 0,
        "minimum": 0,
        "maximum": 256
    },
    "min_chunk_size": {
        "description": "最小分块大小（字符数）",
        "type": "int",
        "hint": "小于此大小的块会被合并到相邻块中",
        "default": 100,
        "minimum": 50,
        "maximum": 512
    },
    "use_semantic_chunking": {
        "description": "是否启用语义感知分块",
        "type": "bool",
        "hint": "启用后将使用基于标题和段落边界的智能分块策略",
        "default": true
    },
    "multimodal": {
        "description": "多模态向量化配置",
        "type": "object",
        "hint": "配置图片、表格、公式的提取和向量化",
        "obvious_hint": true,
        "items": {
            "enabled": {
                "description": "是否启用多模态处理",
                "type": "bool",
                "default": false,
                "hint": "启用后将提取PDF中的图片、表格、公式并进行向量化。需要安装额外依赖（transformers、torch）"
            },
            "extract_images": {
                "description": "是否提取图片",
                "type": "bool",
                "default": true
            },
            "extract_tables": {
                "description": "是否提取表格",
                "type": "bool",
                "default": true
            },
            "extract_formulas": {
                "description": "是否提取公式",
                "type": "bool",
                "default": true
            },
            "vision_model": {
                "description": "视觉编码器模型",
                "type": "string",
                "default": "siglip-so400m",
                "hint": "可选: siglip-base, siglip-so400m (推荐), siglip-large",
                "enum": ["siglip-base", "siglip-so400m", "siglip-large"]
            },
            "vision_device": {
                "description": "视觉编码器运行设备",
                "type": "string",
                "default": "cpu",
                "hint": "auto（自动检测）, cpu（CPU）, cuda（GPU，需要CUDA支持）",
                "enum": ["auto", "cpu", "cuda"]
            },
            "text_weight": {
                "description": "文本嵌入权重（混合检索）",
                "type": "float",
                "default": 0.6,
                "minimum": 0.0,
                "maximum": 1.0
            },
            "vision_weight": {
                "description": "视觉嵌入权重（混合检索）",
                "type": "float",
                "default": 0.4,
                "minimum": 0.0,
                "maximum": 1.0
            }
        }
    },
    "enable_reranking": {
        "description": "是否启用重排序功能",
        "type": "bool",
        "hint": "启用后将使用交叉注意力模型对检索结果进行精确重排序，提升15-25%的检索精度。需要安装 FlagEmbedding 依赖（pip install -U FlagEmbedding）。会增加200-500ms延迟",
        "default": false
    },
    "reranking_model": {
        "description": "重排序模型名称",
        "type": "string",
        "hint": "HuggingFace 模型名称或本地路径。推荐使用 BAAI/bge-reranker-v2-m3（多语言支持）",
        "obvious_hint": true,
        "default": "BAAI/bge-reranker-v2-m3",
        "minLength": 1,
        "enum": [
            "BAAI/bge-reranker-v2-m3",
            "BAAI/bge-reranker-large",
            "BAAI/bge-reranker-base"
        ]
    },
    "reranking_device": {
        "description": "重排序模型运行设备",
        "type": "string",
        "hint": "auto: 自动检测MPS/CUDA/CPU（推荐）；mps: Apple Silicon GPU加速；cuda: NVIDIA GPU加速；cpu: CPU运行",
        "obvious_hint": true,
        "default": "auto",
        "enum": ["auto", "mps", "cuda", "cpu"]
    },
    "reranking_adaptive": {
        "description": "是否使用自适应重排序",
        "type": "bool",
        "hint": "启用后将根据结果数量和相似度分布智能决定是否重排序，避免不必要的时间消耗",
        "default": true
    },
    "reranking_threshold": {
        "description": "重排序分数阈值",
        "type": "float",
        "hint": "过滤掉低于此分数的重排序结果（0-1之间）。设置为0表示保留所有结果",
        "default": 0.0,
        "minimum": 0.0,
        "maximum": 1.0
    },
    "reranking_batch_size": {
        "description": "重排序批处理大小",
        "type": "int",
        "hint": "批量处理文档数量，影响推理速度和内存占用。较大的值速度更快但占用更多内存",
        "default": 32,
        "minimum": 1,
        "maximum": 128
    },
    "ollama": {
        "description": "Ollama本地Embedding配置",
        "type": "object",
        "hint": "配置Ollama服务进行本地embedding（需要先安装并启动Ollama）。仅在embedding_mode='ollama'时生效",
        "obvious_hint": true,
        "items": {
            "base_url": {
                "description": "Ollama服务地址",
                "type": "string",
                "default": "http://localhost:11434",
                "hint": "Ollama服务的HTTP API地址。默认使用本地11434端口"
            },
            "model": {
                "description": "Ollama模型名称",
                "type": "string",
                "default": "bge-m3",
                "hint": "Ollama中已安装的模型名称。常用模型: bge-m3（推荐1024维）、nomic-embed-text（768维）、mxbai-embed-large（1024维）"
            },
            "timeout": {
                "description": "请求超时时间（秒）",
                "type": "float",
                "default": 120.0,
                "minimum": 10.0,
                "maximum": 600.0,
                "hint": "单个请求的超时时间。首次运行模型加载可能需要较长时间"
            },
            "batch_size": {
                "description": "并发批处理大小",
                "type": "int",
                "default": 10,
                "minimum": 1,
                "maximum": 50,
                "hint": "同时处理的文本数量。较大的值速度更快但占用更多内存"
            },
            "retry_attempts": {
                "description": "失败重试次数",
                "type": "int",
                "default": 3,
                "minimum": 0,
                "maximum": 10,
                "hint": "请求失败时的重试次数"
            }
        }
    }
}
